generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  email       String   @unique
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizedPools Pool[]       @relation("Organizer")
  memberships    PoolMember[]
  entries        Entry[]
}

model Tournament {
  id               String           @id @default(cuid())
  name             String
  course           String?
  startDate        DateTime
  endDate          DateTime
  status           TournamentStatus @default(UPCOMING)
  year             Int
  slashGolfTournId String?
  lastSyncAt       DateTime?
  createdAt        DateTime         @default(now())

  pools  Pool[]
  scores GolferScore[]
}

enum TournamentStatus {
  UPCOMING
  LIVE
  COMPLETE
}

model Golfer {
  id          String    @id @default(cuid())
  slashGolfId String?   @unique
  name        String
  country     String?
  owgr        Int?
  imageUrl    String?
  birthDate   DateTime?
  majorWins   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  categoryAssignments CategoryGolfer[]
  picks               Pick[]
  replacedPicks       Pick[]           @relation("OriginalGolfer")
  scores              GolferScore[]
}

model Pool {
  id               String     @id @default(cuid())
  name             String
  organizerId      String
  tournamentId     String
  inviteCode       String     @unique
  picksDeadline    DateTime
  status           PoolStatus @default(SETUP)
  acceptingMembers Boolean    @default(true)
  maxEntries       Int        @default(1)
  rules            String?
  scoringType           String  @default("to-par")
  missedCutPenaltyType  String  @default("carry-score")
  missedCutFixedPenalty Int?    @default(4)
  tiebreakerRule        String  @default("entry-timestamp")
  rosterRule            String  @default("all-play")
  rosterRuleMode        String  @default("per-tournament")
  rosterRuleCount       Int?
  scoringCustomText     String?
  missedCutCustomText   String?
  tiebreakerCustomText  String?
  entryFee         String?
  paymentInfo      String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  organizer           User                 @relation("Organizer", fields: [organizerId], references: [id])
  tournament          Tournament           @relation(fields: [tournamentId], references: [id])
  categories          Category[]
  members             PoolMember[]
  entries             Entry[]
  guestPlayers        GuestPlayer[]
  pendingReplacements PendingReplacement[]
  invites             PoolInvite[]
}

enum PoolStatus {
  SETUP
  OPEN
  LOCKED
  LIVE
  COMPLETE
  ARCHIVED
}

model PoolMember {
  id       String   @id @default(cuid())
  poolId   String
  userId   String
  role     PoolRole @default(PLAYER)
  hasPaid  Boolean  @default(false)
  joinedAt DateTime @default(now())

  pool Pool @relation(fields: [poolId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([poolId, userId])
}

enum PoolRole {
  ORGANIZER
  PLAYER
}

model Category {
  id        String   @id @default(cuid())
  poolId    String
  name      String
  qualifier String?
  sortOrder Int
  createdAt DateTime @default(now())

  pool    Pool             @relation(fields: [poolId], references: [id])
  golfers CategoryGolfer[]
  picks   Pick[]
}

model CategoryGolfer {
  id         String @id @default(cuid())
  categoryId String
  golferId   String

  category Category @relation(fields: [categoryId], references: [id])
  golfer   Golfer   @relation(fields: [golferId], references: [id])

  @@unique([categoryId, golferId])
}

model Entry {
  id             String   @id @default(cuid())
  poolId         String
  userId         String?
  guestPlayerId  String?
  entryNumber    Int      @default(1)
  teamName       String   @default("")
  teamScore      Float?
  rank           Int?
  previousRank   Int?
  paymentStatus  String   @default("unpaid")
  submittedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pool        Pool         @relation(fields: [poolId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
  guestPlayer GuestPlayer? @relation(fields: [guestPlayerId], references: [id])
  picks       Pick[]

  @@unique([poolId, userId, entryNumber])
}

model Pick {
  id               String  @id @default(cuid())
  entryId          String
  categoryId       String
  golferId         String
  isReplacement    Boolean @default(false)
  originalGolferId String?

  entry          Entry    @relation(fields: [entryId], references: [id])
  category       Category @relation(fields: [categoryId], references: [id])
  golfer         Golfer   @relation(fields: [golferId], references: [id])
  originalGolfer Golfer?  @relation("OriginalGolfer", fields: [originalGolferId], references: [id])

  @@unique([entryId, categoryId])
}

model GolferScore {
  id             String   @id @default(cuid())
  golferId       String
  tournamentId   String
  round          Int
  holesCompleted Int      @default(0)
  roundScore     Int?
  totalScore     Int?
  position       String?
  updatedAt      DateTime @updatedAt

  golfer     Golfer     @relation(fields: [golferId], references: [id])
  tournament Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([golferId, tournamentId, round])
}

model PendingReplacement {
  id                  String    @id @default(cuid())
  poolId              String
  pickId              String
  originalGolferId    String
  replacementGolferId String
  reason              String // "WD" or "CUT"
  status              String    @default("PENDING") // PENDING, CONFIRMED, OVERRIDDEN
  confirmedAt         DateTime?
  createdAt           DateTime  @default(now())

  pool Pool @relation(fields: [poolId], references: [id])
}

model GuestPlayer {
  id          String   @id @default(cuid())
  poolId      String
  displayName String
  email       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pool    Pool    @relation(fields: [poolId], references: [id])
  entries Entry[]

  @@unique([poolId, email])
}

model PoolInvite {
  id        String   @id @default(cuid())
  poolId    String
  email     String
  status    String   @default("pending") // pending, sent, failed
  sentAt    DateTime?
  createdAt DateTime @default(now())

  pool Pool @relation(fields: [poolId], references: [id])

  @@unique([poolId, email])
}

model TransferRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  poolType    String
  description String
  fileData    String?
  fileName    String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
